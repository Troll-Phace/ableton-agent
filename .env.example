# Ableton Claude Agent — environment template.
# Copy to `.env` (which is gitignored). Do NOT commit real values.

# Absolute path to Live's native Extension Host module
# (ExtensionHostNodeModule.node), consumed by @ableton-extensions/cli to run the
# extension inside Live. This is auto-populated per-machine by the SDK
# create-extension scaffolder — its value differs on every developer's machine,
# so it must not be checked in.
EXTENSION_HOST_PATH=

# NOTE: The Anthropic API key is NOT an environment variable. Per
# docs/ARCHITECTURE.md section 10 it lives in the SDK storageDirectory's
# config.json, is read in Node only, and is never written into anything the
# webview receives.
