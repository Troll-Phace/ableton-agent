{
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "esnext",
    "lib": ["esnext"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["tests/**/*", "src/shared/**/*", "src/extension/**/*"],
  "exclude": [
    "tests/webview-render.test.ts",
    "tests/webview-transport.test.ts",
    "tests/webview-close.test.ts"
  ]
}
